ern--codes\\frontend\\src\\screens\\ProductScreen.jsx",["61"],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\components\\Message.jsx",[],["62","63"],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\components\\Product.jsx",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\App.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\actions\\productActions.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\components\\Header.jsx",[],["64","65"],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\components\\Rating.jsx",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\screens\\HomeScreen.jsx",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\constants\\cartConstants.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\reducers\\cartReducers.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\reducers\\productReducers.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\screens\\CartScreen.jsx",["66"],"import React, { useEffect, useState } from \"react\";\r\nimport { useDispatch, useSelector } from \"react-redux\";\r\nimport { Link } from \"react-router-dom\";\r\nimport {\r\n  Row,\r\n  Col,\r\n  ListGroup,\r\n  Image,\r\n  Form,\r\n  Button,\r\n  Card,\r\n} from \"react-bootstrap\";\r\nimport { addToCart, removeFromCart } from \"../actions/cartActions\";\r\nimport Message from \"../components/Message\";\r\n\r\nconst CartScreen = ({ match, location, history }) => {\r\n  const productId = match.params.id;\r\n  const qty = location.search ? Number(location.search.split(\"=\")[1]) : 1;\r\n  const dispatch = useDispatch();\r\n\r\n  const cart = useSelector((state) => state.cart);\r\n  const { cartItems } = cart;\r\n\r\n  console.log(cartItems);\r\n\r\n  useEffect(() => {\r\n    if (productId) {\r\n      dispatch(addToCart(productId, qty));\r\n    }\r\n  }, [dispatch, productId, qty]);\r\n\r\n  const removeFromCartHandler = (id) => {\r\n    dispatch(removeFromCart(id));\r\n  };\r\n\r\n  const checkOutHandler = () => {\r\n    history.push(\"/login?redirect=shipping\");\r\n  };\r\n\r\n  return (\r\n    <Row>\r\n      <Col md={8}>\r\n        <h1>Shopping Cart</h1>\r\n        {cartItems.length === 0 ? (\r\n          <Message>\r\n            Your shopping cart is empty. <Link to=\"/\">Go Back</Link>\r\n          </Message>\r\n        ) : (\r\n          <ListGroup variant=\"flush\">\r\n            {cartItems.map((item) => (\r\n              <ListGroup.Item key={item.product}>\r\n                <Row>\r\n                  <Col md={2}>\r\n                    <Image src={item.image} alt={item.name} fluid rounded />\r\n                  </Col>\r\n\r\n                  <Col md={3}>\r\n                    <Link to={`/product/${item.product}`}>{item.name}</Link>\r\n                  </Col>\r\n\r\n                  <Col md={2}>${item.price}</Col>\r\n\r\n                  <Col md={2}>\r\n                    <Form.Control\r\n                      as=\"select\"\r\n                      value={item.qty}\r\n                      onChange={(e) =>\r\n                        dispatch(addToCart(item.product, e.target.value))\r\n                      }\r\n                    >\r\n                      {[...Array(item.countInStock).keys()].map((qty) => (\r\n                        <option value={qty + 1} key={qty + 1}>\r\n                          {qty + 1}\r\n                        </option>\r\n                      ))}\r\n                    </Form.Control>\r\n                  </Col>\r\n\r\n                  <Col md={2}>\r\n                    <Button\r\n                      onClick={() => removeFromCartHandler(item.product)}\r\n                      type=\"button\"\r\n                      variant=\"light\"\r\n                    >\r\n                      <i className=\"fas fa-trash\" />\r\n                    </Button>\r\n                  </Col>\r\n                </Row>\r\n              </ListGroup.Item>\r\n            ))}\r\n          </ListGroup>\r\n        )}\r\n      </Col>\r\n\r\n      <Col md={4}>\r\n        <Card>\r\n          <ListGroup variant=\"flush\">\r\n            <ListGroup.Item>\r\n              <h2>\r\n                Subtotal ({cartItems.reduce((acc, item) => acc + +item.qty, 0)})\r\n                items\r\n              </h2>\r\n              ${cartItems.reduce((acc, item) => acc + item.price * item.qty, 0)}\r\n            </ListGroup.Item>\r\n\r\n            <ListGroup.Item>\r\n              <Button\r\n                type=\"button\"\r\n                className=\"btn-block\"\r\n                disabled={cartItems.length === 0}\r\n                onClick={checkOutHandler}\r\n              >\r\n                Proceed to Checkout\r\n              </Button>\r\n            </ListGroup.Item>\r\n          </ListGroup>\r\n        </Card>\r\n      </Col>\r\n    </Row>\r\n  );\r\n};\r\n\r\nexport default CartScreen;\r\n","C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\actions\\cartActions.js",[],{"ruleId":"67","severity":1,"message":"68","line":30,"column":6,"nodeType":"69","endLine":30,"endColumn":16,"suggestions":"70"},{"ruleId":"71","replacedBy":"72"},{"ruleId":"73","replacedBy":"74"},{"ruleId":"71","replacedBy":"75"},{"ruleId":"73","replacedBy":"76"},{"ruleId":"77","severity":1,"message":"78","line":1,"column":28,"nodeType":"79","messageId":"80","endLine":1,"endColumn":36},"react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'match.params.id'. Either include it or remove the dependency array.","ArrayExpression",["81"],"no-native-reassign",["82"],"no-negated-in-lhs",["83"],["82"],["83"],"no-unused-vars","'useState' is defined but never used.","Identifier","unusedVar",{"desc":"84","fix":"85"},"no-global-assign","no-unsafe-negation","Update the dependencies array to be: [dispatch, match.params.id]",{"range":"86","text":"87"},[785,795],"[dispatch, match.params.id]"]