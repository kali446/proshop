ath":"86","messages":"87","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"55"},{"filePath":"88","messages":"89","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"90"},{"filePath":"91","messages":"92","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"93","messages":"94","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"95","messages":"96","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"97","messages":"98","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"55"},{"filePath":"99","messages":"100","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"101","messages":"102","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\store.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\screens\\ProductScreen.jsx",["103"],"import React, { useEffect, useState } from \"react\";\r\nimport { useDispatch, useSelector } from \"react-redux\";\r\nimport { listProductDetail } from \"../actions/productActions\";\r\nimport { Link } from \"react-router-dom\";\r\nimport {\r\n  Row,\r\n  Col,\r\n  Image,\r\n  ListGroup,\r\n  Card,\r\n  Button,\r\n  Form,\r\n} from \"react-bootstrap\";\r\nimport Rating from \"../components/Rating\";\r\nimport Loader from \"../components/Loader\";\r\nimport Message from \"../components/Message\";\r\n\r\nconst ProductScreen = ({ match, history }) => {\r\n  // states\r\n  const [qty, setQty] = useState(1);\r\n\r\n  // redux part\r\n  const dispatch = useDispatch();\r\n  const { product, loading, error } = useSelector(\r\n    (state) => state.productDetail\r\n  );\r\n\r\n  useEffect(() => {\r\n    dispatch(listProductDetail(match.params.id));\r\n  }, [dispatch]);\r\n\r\n  const addToCartHandler = () => {\r\n    history.push(`/cart/${match.params.id}?qty=${qty}`);\r\n  };\r\n\r\n  return (\r\n    <>\r\n      <Link className=\"btn btn-light my-3\" to=\"/\">\r\n        Go Back\r\n      </Link>\r\n\r\n      {loading ? (\r\n        <Loader />\r\n      ) : error ? (\r\n        <Message variant=\"danger\">{error}</Message>\r\n      ) : (\r\n        <Row>\r\n          <Col md={6} sm={12}>\r\n            <Image src={product.image} alt={product.name} fluid />\r\n          </Col>\r\n\r\n          <Col md={3} sm={12}>\r\n            <ListGroup variant=\"flush\">\r\n              <ListGroup.Item>\r\n                <h3>{product.name}</h3>\r\n              </ListGroup.Item>\r\n              <ListGroup.Item>\r\n                <Rating\r\n                  value={product.rating}\r\n                  text={`${product.numReviews} reviews`}\r\n                />\r\n              </ListGroup.Item>\r\n              <ListGroup.Item>Price: ${product.price}</ListGroup.Item>\r\n              <ListGroup.Item>\r\n                Description: {product.description}\r\n              </ListGroup.Item>\r\n            </ListGroup>\r\n          </Col>\r\n\r\n          <Col md={3} sm={12}>\r\n            <Card>\r\n              <ListGroup variant=\"flush\">\r\n                <ListGroup.Item>\r\n                  <Row>\r\n                    <Col>Price:</Col>\r\n                    <Col>\r\n                      <strong>${product.price}</strong>\r\n                    </Col>\r\n                  </Row>\r\n                </ListGroup.Item>\r\n\r\n                <ListGroup.Item>\r\n                  <Row>\r\n                    <Col>Status:</Col>\r\n                    <Col>\r\n                      {product.countInStock > 0 ? \"In Stock\" : \"Out Of Stock\"}\r\n                    </Col>\r\n                  </Row>\r\n                </ListGroup.Item>\r\n\r\n                {product.countInStock > 0 && (\r\n                  <ListGroup.Item>\r\n                    <Row>\r\n                      <Col>Qty</Col>\r\n                      <Col>\r\n                        <Form.Control\r\n                          as=\"select\"\r\n                          value={qty}\r\n                          onChange={(e) => setQty(e.target.value)}\r\n                        >\r\n                          {[...Array(product.countInStock).keys()].map(\r\n                            (qty) => (\r\n                              <option value={qty + 1} key={qty + 1}>\r\n                                {qty + 1}\r\n                              </option>\r\n                            )\r\n                          )}\r\n                        </Form.Control>\r\n                      </Col>\r\n                    </Row>\r\n                  </ListGroup.Item>\r\n                )}\r\n\r\n                <ListGroup.Item>\r\n                  <Button\r\n                    onClick={addToCartHandler}\r\n                    className=\"btn-block\"\r\n                    type=\"button\"\r\n                    disabled={product.countInStock === 0}\r\n                  >\r\n                    Add To Cart\r\n                  </Button>\r\n                </ListGroup.Item>\r\n              </ListGroup>\r\n            </Card>\r\n          </Col>\r\n        </Row>\r\n      )}\r\n    </>\r\n  );\r\n};\r\n\r\nexport default ProductScreen;\r\n",["104","105"],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\components\\Message.jsx",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\components\\Product.jsx",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\App.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\actions\\productActions.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\components\\Header.jsx",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\components\\Rating.jsx",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\screens\\HomeScreen.jsx",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\constants\\cartConstants.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\reducers\\cartReducers.js",[],["106","107"],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\reducers\\productReducers.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\screens\\CartScreen.jsx",["108"],"import React, { useEffect, useState } from \"react\";\r\nimport { useDispatch, useSelector } from \"react-redux\";\r\nimport { Link } from \"react-router-dom\";\r\nimport {\r\n  Row,\r\n  Col,\r\n  ListGroup,\r\n  Image,\r\n  Form,\r\n  Button,\r\n  Card,\r\n} from \"react-bootstrap\";\r\nimport { addToCart, removeFromCart } from \"../actions/cartActions\";\r\nimport Message from \"../components/Message\";\r\n\r\nconst CartScreen = ({ match, location, history }) => {\r\n  const productId = match.params.id;\r\n  const qty = location.search ? Number(location.search.split(\"=\")[1]) : 1;\r\n  const dispatch = useDispatch();\r\n\r\n  const cart = useSelector((state) => state.cart);\r\n  const { cartItems } = cart;\r\n\r\n  console.log(cartItems);\r\n\r\n  useEffect(() => {\r\n    if (productId) {\r\n      dispatch(addToCart(productId, qty));\r\n    }\r\n  }, [dispatch, productId, qty]);\r\n\r\n  const removeFromCartHandler = (id) => {\r\n    dispatch(removeFromCart(id));\r\n  };\r\n\r\n  const checkOutHandler = () => {\r\n    history.push(\"/login?redirect=shipping\");\r\n  };\r\n\r\n  return (\r\n    <Row>\r\n      <Col md={8}>\r\n        <h1>Shopping Cart</h1>\r\n        {cartItems.length === 0 ? (\r\n          <Message>\r\n            Your shopping cart is empty. <Link to=\"/\">Go Back</Link>\r\n          </Message>\r\n        ) : (\r\n          <ListGroup variant=\"flush\">\r\n            {cartItems.map((item) => (\r\n              <ListGroup.Item key={item.product}>\r\n                <Row>\r\n                  <Col md={2}>\r\n                    <Image src={item.image} alt={item.name} fluid rounded />\r\n                  </Col>\r\n\r\n                  <Col md={3}>\r\n                    <Link to={`/product/${item.product}`}>{item.name}</Link>\r\n                  </Col>\r\n\r\n                  <Col md={2}>${item.price}</Col>\r\n\r\n                  <Col md={2}>\r\n                    <Form.Control\r\n                      as=\"select\"\r\n                      value={item.qty}\r\n                      onChange={(e) =>\r\n                        dispatch(addToCart(item.product, e.target.value))\r\n                      }\r\n                    >\r\n                      {[...Array(item.countInStock).keys()].map((qty) => (\r\n                        <option value={qty + 1} key={qty + 1}>\r\n                          {qty + 1}\r\n                        </option>\r\n                      ))}\r\n                    </Form.Control>\r\n                  </Col>\r\n\r\n                  <Col md={2}>\r\n                    <Button\r\n                      onClick={() => removeFromCartHandler(item.product)}\r\n                      type=\"button\"\r\n                      variant=\"light\"\r\n                    >\r\n                      <i className=\"fas fa-trash\" />\r\n                    </Button>\r\n                  </Col>\r\n                </Row>\r\n              </ListGroup.Item>\r\n            ))}\r\n          </ListGroup>\r\n        )}\r\n      </Col>\r\n\r\n      <Col md={4}>\r\n        <Card>\r\n          <ListGroup variant=\"flush\">\r\n            <ListGroup.Item>\r\n              <h2>\r\n                Subtotal ({cartItems.reduce((acc, item) => acc + +item.qty, 0)})\r\n                items\r\n              </h2>\r\n              ${cartItems.reduce((acc, item) => acc + item.price * item.qty, 0)}\r\n            </ListGroup.Item>\r\n\r\n            <ListGroup.Item>\r\n              <Button\r\n                type=\"button\"\r\n                className=\"btn-block\"\r\n                disabled={cartItems.length === 0}\r\n                onClick={checkOutHandler}\r\n              >\r\n                Proceed to Checkout\r\n              </Button>\r\n            </ListGroup.Item>\r\n          </ListGroup>\r\n        </Card>\r\n      </Col>\r\n    </Row>\r\n  );\r\n};\r\n\r\nexport default CartScreen;\r\n","C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\actions\\cartActions.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\index.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\components\\Footer.jsx",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\constants\\productConstants.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\components\\Loader.jsx",[],["109","110"],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\constants\\userConstants.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\reducers\\userReducers.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\actions\\userActions.js",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\screens\\LoginScreen.jsx",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\components\\FormContainer.jsx",[],"C:\\Users\\manji\\3D Objects\\mern--codes\\frontend\\src\\screens\\ProfileScreen.jsx",[],{"ruleId":"111","severity":1,"message":"112","line":30,"column":6,"nodeType":"113","endLine":30,"endColumn":16,"suggestions":"114"},{"ruleId":"115","replacedBy":"116"},{"ruleId":"117","replacedBy":"118"},{"ruleId":"115","replacedBy":"119"},{"ruleId":"117","replacedBy":"120"},{"ruleId":"121","severity":1,"message":"122","line":1,"column":28,"nodeType":"123","messageId":"124","endLine":1,"endColumn":36},{"ruleId":"115","replacedBy":"125"},{"ruleId":"117","replacedBy":"126"},"react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'match.params.id'. Either include it or remove the dependency array.","ArrayExpression",["127"],"no-native-reassign",["128"],"no-negated-in-lhs",["129"],["128"],["129"],"no-unused-vars","'useState' is defined but never used.","Identifier","unusedVar",["128"],["129"],{"desc":"130","fix":"131"},"no-global-assign","no-unsafe-negation","Update the dependencies array to be: [dispatch, match.params.id]",{"range":"132","text":"133"},[785,795],"[dispatch, match.params.id]"]